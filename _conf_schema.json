{
  "title_text": {
    "description": "标题文字",
    "type": "string",
    "default": "系统状态",
    "hint": "会显示在文字回复的第一行。"
  },
  "show_host": {
    "description": "显示主机名",
    "type": "bool",
    "default": true
  },
  "show_os": {
    "description": "显示系统信息",
    "type": "bool",
    "default": true
  },
  "show_cpu_name": {
    "description": "显示处理器名称",
    "type": "bool",
    "default": true
  },
  "show_cpu_usage": {
    "description": "显示处理器占用",
    "type": "bool",
    "default": true
  },
  "show_cpu_temp": {
    "description": "显示处理器温度（尽力而为）",
    "type": "bool",
    "default": true,
    "hint": "温度依赖系统/驱动与传感器来源，可能显示为暂无。"
  },
  "show_memory": {
    "description": "显示内存占用",
    "type": "bool",
    "default": true
  },
  "show_gpu_usage": {
    "description": "显示显卡占用（尽力而为）",
    "type": "bool",
    "default": true,
    "hint": "优先使用 nvidia-smi；也会尝试从硬件监控 WMI 读取。"
  },
  "show_gpu_name": {
    "description": "显示显卡名称",
    "type": "bool",
    "default": true
  },
  "show_gpu_temp": {
    "description": "显示显卡温度（尽力而为）",
    "type": "bool",
    "default": true
  },
  "show_gpu_memory": {
    "description": "显示显存占用（尽力而为）",
    "type": "bool",
    "default": true
  },
  "show_timestamp": {
    "description": "显示时间",
    "type": "bool",
    "default": true
  }
}
