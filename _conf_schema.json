{
  "title_text": {
    "description": "标题文字",
    "type": "string",
    "default": "系统状态",
    "hint": "会显示在文字回复的第一行。"
  },
  "data_source": {
    "description": "数据来源",
    "type": "string",
    "options": ["本机", "远程"],
    "default": "本机",
    "hint": "选择远程时将从远程 Agent 拉取 /status 数据。"
  },
  "remote_hosts": {
    "description": "远程主机列表",
    "type": "template_list",
    "default": [],
    "hint": "配置一台或多台远程主机（局域网建议配合防火墙白名单与 Token）。",
    "templates": {
      "host": {
        "name": "远程主机",
        "items": {
          "alias": {
            "description": "别名",
            "type": "string",
            "default": ""
          },
          "url": {
            "description": "URL",
            "type": "string",
            "default": "http://192.168.1.50:8765"
          },
          "token": {
            "description": "Token（可选）",
            "type": "string",
            "default": ""
          },
          "enabled": {
            "description": "启用",
            "type": "bool",
            "default": true
          }
        }
      }
    }
  },
  "remote_default_alias": {
    "description": "默认远程别名",
    "type": "string",
    "default": "",
    "hint": "当数据来源为远程且命令不带参数时，优先使用该别名。"
  },
  "show_host": {
    "description": "显示主机名",
    "type": "bool",
    "default": true
  },
  "show_os": {
    "description": "显示系统信息",
    "type": "bool",
    "default": true
  },
  "show_cpu_name": {
    "description": "显示处理器名称",
    "type": "bool",
    "default": true
  },
  "show_cpu_usage": {
    "description": "显示处理器占用",
    "type": "bool",
    "default": true
  },
  "show_cpu_temp": {
    "description": "显示处理器温度（尽力而为）",
    "type": "bool",
    "default": true,
    "hint": "温度依赖系统/驱动与传感器来源，可能显示为暂无。"
  },
  "show_memory": {
    "description": "显示内存占用",
    "type": "bool",
    "default": true
  },
  "show_gpu_usage": {
    "description": "显示显卡占用（尽力而为）",
    "type": "bool",
    "default": true,
    "hint": "优先使用 nvidia-smi；也会尝试从硬件监控 WMI 读取。"
  },
  "show_gpu_name": {
    "description": "显示显卡名称",
    "type": "bool",
    "default": true
  },
  "show_gpu_temp": {
    "description": "显示显卡温度（尽力而为）",
    "type": "bool",
    "default": true
  },
  "show_gpu_memory": {
    "description": "显示显存占用（尽力而为）",
    "type": "bool",
    "default": true
  },
  "show_timestamp": {
    "description": "显示时间",
    "type": "bool",
    "default": true
  }
}
